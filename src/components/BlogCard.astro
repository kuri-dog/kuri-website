---
interface Props {
  title: string;
  excerpt: string;
  date: string;
  category: string;
  href: string;
  coverImage?: string;
  coverAlt?: string;
  featured?: boolean;
}

const { title, excerpt, date, category, href, coverImage, coverAlt = "", featured = false } = Astro.props;
const formattedDate = new Intl.DateTimeFormat("en-NZ", {
  day: "numeric",
  month: "long",
  year: "numeric",
}).format(new Date(date));
---

<article class:list={["blog-card", { featured }]}>
  {coverImage && (
    <a class="blog-image" href={href} aria-label={`Read ${title}`}>
      <img src={coverImage} alt={coverAlt} loading={featured ? "eager" : "lazy"} />
    </a>
  )}
  <div class="blog-card-body">
    <span class="blog-category">{category}</span>
    <h2><a href={href}>{title}</a></h2>
    <time datetime={date}>{formattedDate}</time>
    <p>{excerpt}</p>
    <a class="read-more" href={href}>Read article</a>
  </div>
</article>

<style>
  .blog-card {
    display: grid;
    min-height: 100%;
    overflow: hidden;
    border: 1px solid var(--kuri-line);
    border-radius: 8px;
    background: var(--kuri-white);
    box-shadow: 0 2px 8px rgb(0 0 0 / 5%);
  }

  .blog-card.featured {
    grid-template-columns: minmax(0, 1.02fr) minmax(0, 0.98fr);
    border-color: var(--kuri-red);
  }

  .blog-image {
    min-height: 260px;
    background: var(--kuri-ink);
  }

  .blog-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .blog-card-body {
    display: flex;
    flex-direction: column;
    padding: 24px;
  }

  .blog-category {
    margin-bottom: 10px;
    color: var(--kuri-red);
    font-size: 0.82rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  h2 {
    margin-bottom: 8px;
    font-size: clamp(1.45rem, 3vw, 2.25rem);
    line-height: 1.02;
  }

  .blog-card:not(.featured) h2 {
    font-size: 1.35rem;
    line-height: 1.08;
  }

  h2 a,
  .read-more {
    text-decoration: none;
  }

  time {
    margin-bottom: 14px;
    color: var(--kuri-grey);
    font-size: 0.95rem;
  }

  p {
    color: var(--kuri-grey);
  }

  .read-more {
    margin-top: auto;
    color: var(--kuri-red);
    font-weight: 900;
    text-transform: uppercase;
  }

  @media (max-width: 820px) {
    .blog-card.featured {
      grid-template-columns: 1fr;
    }
  }
</style>
