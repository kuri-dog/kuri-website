---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="wrap footer-grid">
    <div class="footer-brand">
      <div class="brand-lockup">
        <strong>KURI</strong>
        <span class="brand-tag">WE LOVE DOGS</span>
      </div>
      <p>KURI - We Love Dogs. Raw dog food, dog training, daycare, grooming and health care in Christchurch.</p>
      <div class="social-links" aria-label="Kuri social media">
        <a class="social-chip" href="https://www.tiktok.com/@kuricitynz" target="_blank" rel="noopener" aria-label="TikTok">T</a>
        <a class="social-chip" href="https://www.instagram.com/kuriwelovedogs/" target="_blank" rel="noopener" aria-label="Instagram">IG</a>
        <a class="social-chip" href="https://www.facebook.com/KuriCityNZ/" target="_blank" rel="noopener" aria-label="Facebook">f</a>
        <a class="social-chip" href="https://www.pinterest.com/" target="_blank" rel="noopener" aria-label="Pinterest">P</a>
      </div>
    </div>

    <nav aria-label="Important links">
      <h3>Important Links</h3>
      <a href="/terms-conditions/">Terms & Conditions</a>
      <a href="/privacy-policy/">Privacy Policy</a>
      <a href="https://shop.kuri.co.nz/">Shop Kuri</a>
      <a href="https://kuri.portal.gingrapp.com/">Book a Service</a>
      <a href="/dog-grooming-christchurch/">Dog Grooming</a>
      <a href="/raw-dog-food/">Raw Dog Food</a>
    </nav>

    <div>
      <h3>Contact us</h3>
      <a class="contact-line" href="tel:033555874">03 355 5874</a>
      <a class="contact-line" href="mailto:reception@kuri.co.nz">reception@kuri.co.nz</a>
      <span class="contact-line">473 Saint Asaph Street, Phillipstown, Christchurch 8011, New Zealand</span>
      <div class="map-embed">
        <iframe
          title="Kuri location map"
          src="https://www.google.com/maps?q=473%20Saint%20Asaph%20Street%2C%20Christchurch&z=15&output=embed"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade">
        </iframe>
      </div>
      <a class="map-link" href="https://www.google.com/maps/search/?api=1&query=473+Saint+Asaph+Street,+Christchurch" target="_blank" rel="noopener">Open in Google Maps</a>
    </div>

    <div>
      <h3>Opening hours</h3>
      <span class="hours-line"><strong>City Centre</strong></span>
      <span class="hours-line">City Centre (Sales)</span>
      <span class="hours-line">Mon to Fri - 7am to 6pm</span>
      <span class="hours-line">Sat - 10am to 2pm (store only)</span>
      <a class="review-badge" href="https://www.google.com/search?q=Kuri+City+Christchurch+reviews" target="_blank" rel="noopener" aria-label="Read Kuri Google reviews">
        <span class="google-g" aria-hidden="true">G</span>
        <span class="review-score">4.9</span>
        <span class="review-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
        <span class="review-number">208</span>
        <span class="review-label">Read our reviews</span>
      </a>
    </div>
  </div>

  <div class="wrap footer-bottom">
    <span>&copy; {year} Kuri and Co Limited</span>
    <span><a href="/privacy-policy/">Privacy Policy</a> | <a href="/terms-conditions/">Terms & Conditions</a></span>
  </div>
</footer>

<style>
  .footer {
    padding: 58px 0 26px;
    background: var(--kuri-ink);
    color: rgb(255 255 255 / 82%);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: minmax(230px, 1.05fr) 0.86fr 1.2fr 0.96fr;
    gap: 36px;
    align-items: start;
  }

  .brand-lockup {
    margin-bottom: 18px;
  }

  .footer strong {
    display: block;
    margin-bottom: 0;
    color: var(--kuri-white);
    font-size: 2.35rem;
    line-height: 1;
  }

  .brand-tag {
    display: block;
    margin-top: 4px;
    color: rgb(255 255 255 / 88%);
    font-size: 0.9rem;
    font-weight: 800;
    letter-spacing: 0.08em;
  }

  .footer p {
    max-width: 320px;
    margin-bottom: 0;
    color: rgb(255 255 255 / 74%);
    font-size: 1rem;
  }

  .footer h3 {
    margin-bottom: 18px;
    color: var(--kuri-white);
    font-size: 1rem;
    text-transform: none;
  }

  .footer a,
  .footer span {
    display: block;
    margin-bottom: 8px;
    color: inherit;
    text-decoration: none;
  }

  .footer a:hover {
    color: var(--kuri-white);
  }

  .social-links {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 24px;
  }

  .footer .social-chip {
    display: inline-flex;
    justify-content: center;
    align-items: center;
    width: 48px;
    height: 48px;
    margin: 0;
    border-radius: 50%;
    background: var(--kuri-red);
    color: var(--kuri-white);
    font-size: 1rem;
    font-weight: 800;
    line-height: 1;
  }

  .footer .social-chip:hover {
    background: #e02020;
    color: var(--kuri-white);
  }

  .contact-line,
  .hours-line {
    color: rgb(255 255 255 / 78%);
  }

  .map-embed {
    margin-top: 16px;
    overflow: hidden;
    border: 1px solid rgb(255 255 255 / 14%);
    border-radius: 8px;
    background: var(--kuri-charcoal);
  }

  .map-embed iframe {
    display: block;
    width: 100%;
    min-height: 210px;
    border: 0;
  }

  .map-link {
    margin-top: 12px;
    color: var(--kuri-white);
    font-weight: 800;
  }

  .footer a.review-badge {
    margin-top: 18px;
    display: grid;
    grid-template-columns: auto auto auto auto;
    column-gap: 6px;
    row-gap: 4px;
    align-items: baseline;
    width: max-content;
    max-width: 100%;
    padding: 0;
    border: 0;
    border-radius: 0;
    background: transparent;
    color: inherit;
    text-decoration: none;
  }

  .footer a.review-badge span {
    margin: 0;
    color: inherit;
  }

  .footer .google-g {
    display: inline-block;
    margin: 0;
    color: var(--kuri-red);
    font-size: 1.85rem;
    font-weight: 800;
    line-height: 1;
    letter-spacing: 0;
  }

  .footer a.review-badge .review-score {
    display: inline;
    margin: 0;
    color: #f4b400;
    font-size: 2rem;
    font-weight: 500;
    line-height: 1;
  }

  .footer a.review-badge .review-stars {
    display: inline;
    margin: 0;
    color: #f4b400;
    font-size: 1.7rem;
    line-height: 1;
    white-space: nowrap;
    letter-spacing: 0;
  }

  .footer a.review-badge .review-number {
    display: inline;
    margin: 0;
    color: rgb(255 255 255 / 58%);
    font-size: 1rem;
    line-height: 1;
  }

  .footer a.review-badge .review-label {
    display: block;
    grid-column: 1 / -1;
    margin: -2px 0 0;
    color: rgb(255 255 255 / 58%);
    font-size: 0.95rem;
    text-align: left;
  }

  .footer-bottom {
    margin-top: 36px;
    padding-top: 20px;
    border-top: 1px solid rgb(255 255 255 / 16%);
    display: flex;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }

  .footer-bottom span,
  .footer-bottom a {
    display: inline;
    margin: 0;
  }

  @media (max-width: 1040px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 700px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
