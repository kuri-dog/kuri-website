---
const navItems = [
  { label: "Grooming", href: "/dog-grooming-christchurch/" },
  { label: "Daycare", href: "/christchurchs-exclusive-small-doggy-daycare/" },
  { label: "Raw Food", href: "/raw-dog-food/" },
  { label: "Blog", href: "/kuri-city-blog/" },
];
---

<header class="site-header" aria-label="Site header">
  <nav class="nav wrap">
    <a class="brand" href="/" aria-label="Kuri home">KURI</a>
    <div class="nav-links" aria-label="Main navigation">
      {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
      <a class="button" href="https://kuri.portal.gingrapp.com/">Book</a>
      <a class="button shop" href="https://shop.kuri.co.nz/">Shop</a>
    </div>
  </nav>
</header>

<style>
  .site-header {
    position: absolute;
    z-index: 5;
    width: 100%;
    color: var(--kuri-white);
  }

  .nav {
    padding: 22px 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .brand {
    color: var(--kuri-white);
    font-size: 2rem;
    font-weight: 900;
    text-decoration: none;
    letter-spacing: 0;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 22px;
    font-size: 0.93rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .nav-links a {
    text-decoration: none;
  }

  .nav-links .button {
    min-height: 40px;
    padding: 0 16px;
  }

  .nav-links .shop {
    background: var(--kuri-white);
    color: var(--kuri-ink);
    border-color: var(--kuri-white);
  }

  @media (max-width: 820px) {
    .nav-links a:not(.button) {
      display: none;
    }
  }

  @media (max-width: 520px) {
    .brand {
      font-size: 1.6rem;
    }

    .nav-links {
      gap: 8px;
    }
  }
</style>
