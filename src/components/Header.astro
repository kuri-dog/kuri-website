---
const navItems = [
  { label: "Raw Food", href: "/raw-dog-food/" },
  { label: "Daycare", href: "/christchurchs-exclusive-small-doggy-daycare/" },
  { label: "Grooming", href: "/dog-grooming-christchurch/" },
  { label: "Walking", href: "/dog-walking/" },
  { label: "Training", href: "/kuri-dog-training/" },
  { label: "Blog", href: "/kuri-city-blog/" },
];
---

<header class="site-header" aria-label="Site header">
  <nav class="nav wrap">
    <a class="brand" href="/" aria-label="Kuri home">
      <img src="/images/kuri-paw-icon.png" alt="" loading="eager" onerror="this.remove()" />
      <span>KURĪ</span>
    </a>
    <div class="nav-links" aria-label="Main navigation">
      {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
      <a class="button" href="https://kuri.portal.gingrapp.com/">Book</a>
      <a class="button shop" href="https://shop.kuri.co.nz/">Shop</a>
    </div>
  </nav>
</header>

<style>
  .site-header {
    position: absolute;
    z-index: 5;
    width: 100%;
    color: var(--kuri-white);
  }

  .nav {
    padding: 22px 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--kuri-white);
    font-size: 2rem;
    font-weight: 900;
    text-decoration: none;
    letter-spacing: 0;
  }

  .brand img {
    display: block;
    width: 38px;
    height: 38px;
    object-fit: contain;
  }

  .brand span {
    display: inline-block;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 16px;
    font-size: 0.88rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .nav-links a {
    text-decoration: none;
  }

  .nav-links .button {
    min-height: 40px;
    padding: 0 16px;
  }

  .nav-links .shop {
    background: var(--kuri-white);
    color: var(--kuri-ink);
    border-color: var(--kuri-white);
  }

  @media (max-width: 980px) {
    .nav-links a:not(.button) {
      display: none;
    }
  }

  @media (max-width: 520px) {
    .brand {
      font-size: 1.6rem;
    }

    .nav-links {
      gap: 8px;
    }
  }
</style>
