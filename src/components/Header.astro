---
import { site } from "../data/site";

const navItems = [
  { label: "Raw Food", href: "/raw-dog-food/" },
  { label: "Daycare", href: "/christchurchs-exclusive-small-doggy-daycare/" },
  { label: "Grooming", href: "/dog-grooming-christchurch/" },
  { label: "Walking", href: "/dog-walking/" },
  { label: "Training", href: "/kuri-dog-training/" },
  { label: "Blog", href: "/kuri-city-blog/" },
];

const actionItems = [
  { label: "Book", href: site.urls.booking },
  { label: "Shop", href: site.urls.shop },
];
---

<header class="site-header" aria-label="Site header">
  <nav class="nav wrap">
    <a class="brand" href="/" aria-label="Kuri home">
      <img src="/images/kuri-paw-icon.png" alt="" loading="eager" onerror="this.remove()" />
      <span>KURĪ</span>
    </a>
    <div class="nav-links" aria-label="Main navigation">
      {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
      <a class="button" href={site.urls.booking}>Book</a>
      <a class="button shop" href={site.urls.shop}>Shop</a>
      <button class="menu-toggle" type="button" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
    <div class="mobile-menu" id="mobile-menu" hidden>
      <div class="mobile-menu-inner">
        {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
        <div class="mobile-menu-actions">
          {actionItems.map((item) => <a class="button" href={item.href}>{item.label}</a>)}
        </div>
      </div>
    </div>
  </nav>
</header>

<script is:inline>
  const header = document.querySelector(".site-header");
  const menuToggle = header?.querySelector(".menu-toggle");
  const mobileMenu = header?.querySelector("#mobile-menu");

  const closeMenu = () => {
    if (!menuToggle || !mobileMenu) return;
    menuToggle.setAttribute("aria-expanded", "false");
    mobileMenu.setAttribute("hidden", "");
  };

  menuToggle?.addEventListener("click", () => {
    if (!mobileMenu) return;
    const isOpen = menuToggle.getAttribute("aria-expanded") === "true";
    menuToggle.setAttribute("aria-expanded", String(!isOpen));
    mobileMenu.toggleAttribute("hidden", isOpen);
  });

  mobileMenu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", closeMenu);
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") closeMenu();
  });
</script>

<style>
  .site-header {
    position: absolute;
    z-index: 5;
    width: 100%;
    color: var(--kuri-white);
  }

  .nav {
    position: relative;
    padding: 22px 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--kuri-white);
    font-size: 2rem;
    font-weight: 900;
    text-decoration: none;
    letter-spacing: 0;
  }

  .brand img {
    display: block;
    width: 38px;
    height: 38px;
    object-fit: contain;
  }

  .brand span {
    display: inline-block;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 16px;
    font-size: 0.88rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .nav-links a {
    text-decoration: none;
  }

  .nav-links .button {
    width: auto;
    min-height: 40px;
    padding: 0 16px;
  }

  .nav-links .shop {
    background: var(--kuri-white);
    color: var(--kuri-ink);
    border-color: var(--kuri-white);
  }

  .menu-toggle {
    display: none;
    justify-content: center;
    align-items: center;
    flex-direction: column;
    gap: 4px;
    width: 42px;
    height: 40px;
    border: 2px solid rgb(255 255 255 / 86%);
    border-radius: 6px;
    background: rgb(27 27 27 / 34%);
    color: var(--kuri-white);
    cursor: pointer;
  }

  .menu-toggle span {
    display: block;
    width: 17px;
    height: 2px;
    border-radius: 999px;
    background: currentColor;
  }

  .mobile-menu {
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    z-index: 6;
    width: min(340px, calc(100vw - 28px));
  }

  .mobile-menu[hidden] {
    display: none;
  }

  .mobile-menu-inner {
    overflow: hidden;
    border: 1px solid rgb(255 255 255 / 16%);
    border-radius: 8px;
    background: var(--kuri-ink);
    box-shadow: 0 18px 50px rgb(0 0 0 / 28%);
  }

  .mobile-menu a {
    display: block;
    padding: 14px 18px;
    border-bottom: 1px solid rgb(255 255 255 / 10%);
    color: var(--kuri-white);
    font-weight: 800;
    text-decoration: none;
    text-transform: uppercase;
  }

  .mobile-menu a:hover,
  .mobile-menu a:focus-visible {
    background: rgb(255 255 255 / 8%);
  }

  .mobile-menu-actions {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    padding: 14px;
  }

  .mobile-menu-actions .button {
    width: 100%;
    min-height: 42px;
    padding: 0 12px;
    border-bottom: 2px solid var(--kuri-red);
  }

  .mobile-menu-actions .button:last-child {
    background: var(--kuri-white);
    color: var(--kuri-ink);
    border-color: var(--kuri-white);
  }

  @media (max-width: 980px) {
    .nav-links a:not(.button) {
      display: none;
    }

    .menu-toggle {
      display: inline-flex;
    }
  }

  @media (max-width: 520px) {
    .brand {
      font-size: 1.6rem;
    }

    .nav-links {
      gap: 8px;
    }

    .nav-links .button {
      min-height: 38px;
      padding: 0 12px;
      font-size: 0.82rem;
    }

    .menu-toggle {
      width: 40px;
      height: 38px;
    }
  }
</style>
