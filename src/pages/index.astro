---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout
  title="Small Dog Daycare Christchurch | Raw Food | Kuri City"
  description="Christchurch's only daycare built for small dogs. Raw food, grooming, walking, and training - all under one roof. 208 Google reviews. 473 St Asaph Street."
>
  <Header />
  <Hero
    title="Christchurch small dog daycare, grooming, walking, training and raw food"
    slogan="Dog care from one local team who knows your dog's name"
    text="Doggy daycare for small dogs, plus raw food, grooming, walking, and training for dogs of all sizes - all from the same team who know your dog's name. At 473 St Asaph Street, Phillipstown."
    primaryLabel="Book Daycare Assessment"
    primaryHref="https://kuri.portal.gingrapp.com/"
    secondaryLabel="Order Raw Food"
    secondaryHref="https://shop.kuri.co.nz/"
    note="4.9 from 208 Google reviews | Over 2,000 dogs in our care | 10 years in Christchurch"
  />
  <main>
    <section class="trust-strip" aria-label="Kuri trust signals">
      <div class="wrap trust-grid">
        <div class="trust-item">
          <strong>4.9</strong>
          <span>Google rating</span>
        </div>
        <div class="trust-item">
          <strong>208</strong>
          <span>Google reviews</span>
        </div>
        <div class="trust-item">
          <strong>10</strong>
          <span>Years in Christchurch</span>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="wrap section-head">
        <h2>Everything your dog needs</h2>
        <p class="lead">Book small-dog-only daycare, order raw food, book a groom, organise a walk, or ask about training.</p>
      </div>

      <div class="service-grid">
        <article class="service-card featured">
          <div class="service-image">
            <img src="/images/daycare-card.webp" alt="Small dogs enjoying daycare at Kuri" loading="lazy" onerror="this.closest('.service-image').remove()" />
          </div>
          <span class="service-kicker">Small dogs only</span>
          <h3>Doggy Daycare</h3>
          <p>Calm daycare for small dogs who need the right group.</p>
          <ul class="service-points">
            <li>Small dogs only</li>
            <li>Familiar staff</li>
            <li>Structured daily routine</li>
          </ul>
          <a class="button" href="https://kuri.portal.gingrapp.com/">Book a Daycare Assessment</a>
        </article>

        <article class="service-card">
          <h3>Dog Grooming</h3>
          <p>Careful grooming for healthy coats and calmer dogs.</p>
          <ul class="service-points">
            <li>Full grooms</li>
            <li>Bath and tidy</li>
            <li>Puppy groom support</li>
          </ul>
          <a class="button ghost" href="/dog-grooming-christchurch/">Book a Groom</a>
        </article>

        <article class="service-card">
          <h3>Raw Dog Food</h3>
          <p>Fresh New Zealand raw meals made simple.</p>
          <ul class="service-points">
            <li>Pre-portioned medallions</li>
            <li>No recipes or guesswork</li>
            <li>Delivered to your door</li>
          </ul>
          <a class="button ghost" href="https://shop.kuri.co.nz/">Order Raw Food</a>
        </article>

        <article class="service-card">
          <h3>Dog Walking</h3>
          <p>Reliable local walks with a familiar face.</p>
          <ul class="service-points">
            <li>Regular exercise</li>
            <li>Consistent routine</li>
            <li>Careful check-ins</li>
          </ul>
          <a class="button ghost" href="/dog-walking/">Book a Walk</a>
        </article>

        <article class="service-card">
          <h3>Dog Training</h3>
          <p>Positive training for puppies and adults.</p>
          <ul class="service-points">
            <li>Real-world confidence</li>
            <li>Everyday behaviour</li>
            <li>Clear communication</li>
          </ul>
          <a class="button ghost" href="/kuri-dog-training/">Book Training</a>
        </article>
      </div>
    </section>

    <section class="section soft">
      <div class="wrap split">
        <div>
          <div class="section-head">
            <h2>Most dog services are built for every dog. Ours aren't.</h2>
            <p class="lead">Kuri City is Christchurch's only daycare designed specifically for small breeds. No big dogs. No chaos. Just calm, safe playgroups where a 5kg cavoodle is not competing with a labrador for space.</p>
          </div>

          <div class="belief-list">
            <div>
              <h3>Small dogs need the right environment</h3>
              <p>Small dogs have different play styles, different stress responses, and different space needs. A mixed-size environment can create anxiety for smaller breeds, even in well-run daycares.</p>
            </div>
            <div>
              <h3>Daycare is small-dog-only</h3>
              <p>We built Kuri specifically around calm, appropriate groups for small dogs. It is why many dogs come back with waggy tails instead of worn-out nerves.</p>
            </div>
            <div>
              <h3>The rest of Kuri is for all dogs</h3>
              <p>Raw food, grooming, walking and training are available for dogs of all sizes, with the same practical care from one local Christchurch team.</p>
            </div>
          </div>
        </div>

        <aside class="feature-panel">
          <span class="panel-kicker">Proof points</span>
          <h3>Trusted by Christchurch dog owners</h3>
          <div class="metric-list">
            <span><strong class="dynamic-count rolling-count" data-base="2000" data-min-daily="10" data-max-daily="15" data-start-date="2026-05-01" data-seed="dogs-in-care" data-suffix="+">2,000+</strong> dogs in our care</span>
            <span><strong class="rolling-count" data-target="208">208</strong> 5 star Google reviews</span>
            <span><strong class="rolling-count" data-target="10">10</strong> years in Christchurch</span>
            <span><strong class="dynamic-count rolling-count" data-base="1000" data-min-daily="10" data-max-daily="25" data-start-date="2026-05-01" data-seed="dogs-fed-raw-food" data-suffix="+">1,000+</strong> dogs fed raw food</span>
          </div>
          <a class="button light" href="/about-us/">About Kuri</a>
        </aside>
      </div>
    </section>

    <section class="section">
      <div class="wrap split reverse">
        <div class="image-panel">
          <img src="/images/grooming-hero.webp" alt="A freshly groomed small dog standing calmly on a grooming table at Kuri." loading="lazy" />
        </div>
        <div>
          <div class="section-head">
            <h2>What your dog eats matters more than most owners realise.</h2>
            <p class="lead">Kuri raw food is made fresh in New Zealand, pre-portioned, and delivered to your door across Canterbury.</p>
          </div>
          <p>Most dog food is heavily processed and high in starch. Kuri raw food comes in pre-portioned medallions, so there is no measuring, no recipes, and no defrost panic at 6pm. Take it from the freezer the night before, and it is ready in the morning.</p>
          <blockquote>"My dog has been on the Kuri raw food for 8 years. His coat is amazing."</blockquote>
          <p class="proof-line">Over 1,000 dogs fed. Most owners see coat, energy, and stool changes within four weeks.</p>
          <div class="cta-row">
            <a class="button" href="https://shop.kuri.co.nz/">Try the Starter Pack</a>
            <a class="button outline-dark" href="/raw-dog-food/">How Raw Feeding Works</a>
          </div>
        </div>
      </div>
    </section>

    <section class="section reviews-section">
      <div class="wrap">
        <div class="section-head center">
          <h2>What Christchurch dog owners say.</h2>
          <p class="lead">Real feedback from customers who trust Kuri with daycare, grooming and food.</p>
        </div>

        <div class="review-grid">
          <article class="review-card">
            <p>"Our dogs are always happy and excited when they know the car is near Kuri. They go in wagging and come out wagging. That's high praise."</p>
            <strong>Sue Bridges</strong>
            <span>&#9733;&#9733;&#9733;&#9733;&#9733;</span>
          </article>
          <article class="review-card">
            <p>"My Franklin absolutely adores going to daycare here. You can tell they really care - mental stimulation, cuddles, and lots of fun throughout the day."</p>
            <strong>Beccy Thwaite</strong>
            <span>&#9733;&#9733;&#9733;&#9733;&#9733;</span>
          </article>
          <article class="review-card">
            <p>"Shannan and her grooming team cannot be beaten. She is amazing at what she does and how she interacts with my dog."</p>
            <strong>Mark Johnston</strong>
            <span>&#9733;&#9733;&#9733;&#9733;&#9733;</span>
          </article>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="wrap split pricing-split">
        <div>
          <div class="section-head">
            <h2>Daycare pricing. No surprises.</h2>
            <p class="lead">Casual bookings welcome. Regular spots available for weekly attendance.</p>
          </div>
          <p>Spaces are limited. We keep our groups small on purpose - it is part of what makes Kuri different. If you are interested in a regular spot, book an assessment and we will let you know what is available.</p>
          <a class="button" href="https://kuri.portal.gingrapp.com/">Book a Daycare Assessment</a>
        </div>

        <div class="price-card">
          <div><span>Casual full day</span><strong>$56</strong></div>
          <div><span>Casual half day</span><strong>$44</strong></div>
          <div><span>Two dogs, full day</span><strong>$95</strong></div>
          <div><span>Two dogs, half day</span><strong>$72</strong></div>
          <p>Half days: Morning 7.00am-12.30pm. Afternoon 12.30pm-6.00pm.</p>
        </div>
      </div>
    </section>

    <section class="section final-cta">
      <div class="wrap final-cta-inner">
        <div>
          <h2>Your dog deserves somewhere they actually look forward to going.</h2>
          <p>Come and see Kuri City for yourself. We are at 473 St Asaph Street, Phillipstown - about five minutes from the CBD. Free parking on site.</p>
        </div>
        <div class="cta-row">
          <a class="button light" href="https://kuri.portal.gingrapp.com/">Book Now</a>
          <a class="button secondary" href="tel:+6433555874">Call us: (03) 355 5874</a>
        </div>
      </div>
    </section>

    <section id="faq" class="section faq-section">
      <div class="wrap">
        <div class="section-head center">
          <h2>Questions people ask about Kuri.</h2>
        </div>

        <div class="faq-list">
          <details>
            <summary>What makes Kuri City different from other dog daycares in Christchurch?</summary>
            <p>Kuri City is Christchurch's only daycare designed exclusively for small dogs. Groups are kept small and calm, with consistent staff who know each dog by name. With over 10 years of operation and 208 Google reviews, it is one of Christchurch's most trusted dog care centres.</p>
          </details>
          <details>
            <summary>Does Kuri City accept large dogs at daycare?</summary>
            <p>No. Daycare at Kuri City is for small dogs only. Small and large breeds have different play styles and stress responses. Kuri's grooming, walking, training, and raw food services are open to all breeds and sizes.</p>
          </details>
          <details>
            <summary>How does Kuri raw dog food work?</summary>
            <p>Kuri raw food comes pre-portioned in medallions. You order online at shop.kuri.co.nz and it is delivered frozen to your door across Canterbury. No preparation required - thaw overnight, serve in the morning.</p>
          </details>
          <details>
            <summary>How much does doggy daycare cost at Kuri City Christchurch?</summary>
            <p>A casual full day at Kuri City costs $56. A half day is $44. Two dogs for a full day is $95. Morning half days run 7.00am-12.30pm; afternoons run 12.30pm-6.00pm.</p>
          </details>
          <details>
            <summary>How do I start feeding my dog raw food in New Zealand?</summary>
            <p>Start with the Kuri Raw Starter Pack, available at shop.kuri.co.nz. It includes pre-portioned medallions and feeding guidance. Most owners switch gradually over 7-10 days.</p>
          </details>
        </div>
      </div>
    </section>
  </main>
  <Footer />

  <script>
    const formatCounter = (value: number, suffix: string) =>
      `${Math.max(0, Math.round(value)).toLocaleString("en-NZ")}${suffix || ""}`;

    const msPerDay = 24 * 60 * 60 * 1000;

    const utcDateFromString = (dateString: string) => {
      const [year, month, day] = dateString.split("-").map(Number);
      return Date.UTC(year, month - 1, day);
    };

    const currentUtcDate = () => {
      const now = new Date();
      return Date.UTC(now.getUTCFullYear(), now.getUTCMonth(), now.getUTCDate());
    };

    const stableDailyAmount = (seed: string, dateStamp: number, min: number, max: number) => {
      const source = `${seed}:${dateStamp}`;
      let hash = 2166136261;
      for (let index = 0; index < source.length; index += 1) {
        hash ^= source.charCodeAt(index);
        hash = Math.imul(hash, 16777619);
      }

      return min + (Math.abs(hash) % (max - min + 1));
    };

    const weekdayGrowthSince = (options: {
      startDate: string;
      min: number;
      max: number;
      seed: string;
    }) => {
      const start = utcDateFromString(options.startDate);
      const today = currentUtcDate();
      let total = 0;

      for (let dateStamp = start + msPerDay; dateStamp <= today; dateStamp += msPerDay) {
        const day = new Date(dateStamp).getUTCDay();
        if (day === 0 || day === 6) continue;
        total += stableDailyAmount(options.seed, dateStamp, options.min, options.max);
      }

      return total;
    };

    const getCounterTarget = (counter: HTMLElement) => {
      const suffix = counter.dataset.suffix || "";
      if (counter.dataset.base) {
        const base = Number(counter.dataset.base || 0);
        const min = Number(counter.dataset.minDaily || 0);
        const max = Number(counter.dataset.maxDaily || min);
        const startDate = counter.dataset.startDate || "2026-05-01";
        const seed = counter.dataset.seed || counter.dataset.base || "kuri-counter";
        const growth = weekdayGrowthSince({ startDate, min, max, seed });
        return formatCounter(base + growth, suffix);
      }

      return formatCounter(Number(counter.dataset.target || counter.textContent || 0), suffix);
    };

    const buildRollingCounter = (counter: HTMLElement, value: string) => {
      counter.setAttribute("aria-label", value);
      counter.textContent = "";

      let digitIndex = 0;
      value.split("").forEach((character) => {
        if (/\d/.test(character)) {
          const reel = document.createElement("span");
          const stack = document.createElement("span");
          reel.className = "digit-reel";
          reel.setAttribute("aria-hidden", "true");
          stack.className = "digit-stack";
          stack.style.transitionDelay = `${digitIndex * 45}ms`;
          stack.dataset.finalIndex = "20";

          for (let cycle = 0; cycle < 2; cycle += 1) {
            for (let number = 0; number <= 9; number += 1) {
              const digit = document.createElement("span");
              digit.textContent = String(number);
              stack.append(digit);
            }
          }

          const final = document.createElement("span");
          final.textContent = character;
          stack.append(final);
          reel.append(stack);
          counter.append(reel);
          digitIndex += 1;
          return;
        }

        const staticCharacter = document.createElement("span");
        staticCharacter.className = "static-char";
        staticCharacter.setAttribute("aria-hidden", "true");
        staticCharacter.textContent = character;
        counter.append(staticCharacter);
      });
    };

    const rollCounter = (counter: HTMLElement) => {
      counter.classList.add("is-rolling");

      counter.querySelectorAll<HTMLElement>(".digit-stack").forEach((stack) => {
        const finalIndex = Number(stack.dataset.finalIndex || 0);
        stack.style.transform = `translateY(-${finalIndex}em)`;
      });
    };

    const counters = [...document.querySelectorAll<HTMLElement>(".rolling-count")];

    counters.forEach((counter) => {
      const target = getCounterTarget(counter);
      buildRollingCounter(counter, target);
    });

    const rollPanel = (panel: Element) => {
      panel.querySelectorAll<HTMLElement>(".rolling-count").forEach((counter) => rollCounter(counter));
    };

    const panels = [...document.querySelectorAll<HTMLElement>(".feature-panel")];
    const checkPanels = () => {
      panels.forEach((panel) => {
        if (panel.dataset.rolled === "true") return;
        const rect = panel.getBoundingClientRect();
        const isInView = rect.top < window.innerHeight * 0.82 && rect.bottom > window.innerHeight * 0.16;
        if (!isInView) return;
        panel.dataset.rolled = "true";
        rollPanel(panel);
      });
    };

    window.addEventListener("scroll", checkPanels, { passive: true });
    window.addEventListener("resize", checkPanels);
    requestAnimationFrame(checkPanels);
    window.setTimeout(checkPanels, 250);
  </script>
</BaseLayout>

<style>
  .trust-strip {
    background: var(--kuri-light);
    border-bottom: 1px solid var(--kuri-line);
  }

  .trust-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1px;
    background: var(--kuri-line);
  }

  .trust-item {
    min-height: 88px;
    padding: 18px 14px;
    background: var(--kuri-light);
    text-align: center;
  }

  .trust-item strong {
    display: block;
    margin-bottom: 3px;
    color: var(--kuri-red);
    font-family: var(--font-heading);
    font-size: clamp(1.35rem, 4vw, 2.15rem);
    font-weight: 900;
    line-height: 1;
  }

  .trust-item span {
    color: var(--kuri-ink);
    font-size: 0.92rem;
    font-weight: 800;
    line-height: 1.2;
  }

  .service-kicker,
  .panel-kicker {
    display: block;
    margin-bottom: 6px;
    font-size: 0.95rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  .service-grid {
    display: grid;
    grid-template-columns: minmax(270px, 0.95fr) repeat(2, minmax(240px, 1fr));
    gap: 16px;
    width: min(var(--container), calc(100% - 40px));
    margin-inline: auto;
  }

  .service-card,
  .review-card,
  .price-card,
  .faq-list details {
    border: 1px solid var(--kuri-line);
    border-radius: 8px;
    background: var(--kuri-white);
    box-shadow: 0 2px 8px rgb(0 0 0 / 5%);
  }

  .service-card,
  .review-card {
    display: flex;
    flex-direction: column;
    min-height: 100%;
    padding: 24px;
  }

  .service-card.featured {
    grid-row: span 2;
    background: var(--kuri-light);
    border-color: var(--kuri-red);
  }

  .service-image {
    margin: -24px -24px 22px;
    overflow: hidden;
    border-radius: 8px 8px 0 0;
    aspect-ratio: 16 / 10;
    background: var(--kuri-line);
  }

  .service-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .service-card p,
  .service-points,
  .review-card p,
  .belief-list p,
  .feature-panel p,
  .price-card p,
  .faq-list p {
    color: var(--kuri-grey);
  }

  .service-points {
    display: grid;
    gap: 7px;
    margin: 16px 0 24px;
    padding-left: 1.1rem;
    font-size: 1rem;
    line-height: 1.35;
  }

  .service-points li::marker {
    color: var(--kuri-red);
  }

  .service-card .button,
  .feature-panel .button {
    margin-top: auto;
  }

  .button.ghost,
  .button.outline-dark {
    background: transparent;
    color: var(--kuri-red);
    border-color: var(--kuri-red);
  }

  .button.outline-dark {
    color: var(--kuri-ink);
    border-color: var(--kuri-ink);
  }

  .split {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.9fr);
    gap: 34px;
    align-items: center;
  }

  .split.reverse {
    grid-template-columns: minmax(320px, 0.9fr) minmax(0, 1.1fr);
  }

  .belief-list {
    display: grid;
    gap: 18px;
  }

  .feature-panel {
    padding: 32px;
    border-radius: 8px;
    background: var(--kuri-charcoal);
    color: var(--kuri-white);
  }

  .metric-list {
    display: grid;
    gap: 12px;
    margin: 22px 0;
  }

  .metric-list span {
    color: rgb(255 255 255 / 78%);
  }

  .metric-list strong {
    display: block;
    color: var(--kuri-white);
    font-size: 2rem;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }

  .rolling-count {
    height: 1em;
    overflow: hidden;
    white-space: nowrap;
  }

  .rolling-count :global(.digit-reel),
  .rolling-count :global(.static-char) {
    display: inline-block;
    height: 1em;
    vertical-align: top;
  }

  .rolling-count :global(.digit-stack) {
    display: flex;
    flex-direction: column;
    height: auto;
    transform: translateY(0);
    transition: transform 1.25s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform;
  }

  .rolling-count :global(.digit-stack span) {
    display: block;
    height: 1em;
    line-height: 1;
  }

  .rolling-count.is-rolling :global(.digit-reel:nth-child(2n) .digit-stack) {
    transition-duration: 1.38s;
  }

  .image-panel img {
    width: 100%;
    border-radius: 8px;
    object-fit: cover;
  }

  blockquote {
    margin: 22px 0;
    padding: 18px 20px;
    border-left: 4px solid var(--kuri-red);
    background: var(--kuri-light);
    color: var(--kuri-ink);
    font-weight: 700;
  }

  .proof-line {
    font-weight: 800;
    color: var(--kuri-ink);
  }

  .cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 22px;
  }

  .reviews-section,
  .faq-section {
    background: linear-gradient(180deg, var(--kuri-light) 0%, var(--kuri-white) 100%);
  }

  .review-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .review-card strong {
    margin-top: auto;
  }

  .review-card span {
    color: #f4b400;
    font-size: 1.1rem;
  }

  .pricing-split {
    align-items: start;
  }

  .price-card {
    padding: 26px;
  }

  .price-card div {
    display: flex;
    justify-content: space-between;
    gap: 18px;
    padding: 13px 0;
    border-bottom: 1px solid var(--kuri-line);
  }

  .price-card strong {
    color: var(--kuri-red);
    font-size: 1.45rem;
  }

  .price-card p {
    margin: 18px 0 0;
  }

  .final-cta {
    background: var(--kuri-red);
    color: var(--kuri-white);
  }

  .final-cta-inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 30px;
    align-items: center;
  }

  .final-cta p {
    max-width: 720px;
    margin: 0;
    color: rgb(255 255 255 / 86%);
  }

  .faq-list {
    display: grid;
    gap: 12px;
    max-width: 900px;
    margin: 0 auto;
  }

  .faq-list details {
    padding: 18px 22px;
  }

  .faq-list summary {
    cursor: pointer;
    color: var(--kuri-ink);
    font-weight: 800;
  }

  .faq-list p {
    margin: 12px 0 0;
  }

  @media (max-width: 980px) {
    .service-grid,
    .review-grid,
    .split,
    .split.reverse,
    .final-cta-inner {
      grid-template-columns: 1fr 1fr;
    }

    .trust-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .service-card.featured {
      grid-row: auto;
      grid-column: 1 / -1;
    }

    .split.reverse > :first-child {
      order: 2;
    }

    .split.reverse > :last-child {
      order: 1;
    }
