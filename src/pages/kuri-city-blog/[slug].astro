---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

export async function getStaticPaths() {
  const posts = await Astro.glob("../../content/blog/*.md");
  return posts.map((post) => ({
    params: { slug: post.frontmatter.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const data = post.frontmatter as {
  title: string;
  slug: string;
  excerpt: string;
  date: string;
  category: string;
  coverImage?: string;
  coverAlt?: string;
};
const Content = post.Content;
const formattedDate = new Intl.DateTimeFormat("en-NZ", {
  day: "numeric",
  month: "long",
  year: "numeric",
}).format(new Date(data.date));
---

<BaseLayout
  title={`${data.title} | Kuri City Blog`}
  description={data.excerpt}
  canonical={`/kuri-city-blog/${data.slug}/`}
>
  <Header />
  <main>
    <article>
      <header class="post-hero">
        <div class="wrap">
          <a class="back-link" href="/kuri-city-blog/">Kuri City Blog</a>
          <span>{data.category}</span>
          <h1>{data.title}</h1>
          <p>{data.excerpt}</p>
          <time datetime={data.date}>{formattedDate}</time>
        </div>
      </header>

      {data.coverImage && (
        <div class="wrap post-cover">
          <img src={data.coverImage} alt={data.coverAlt} />
        </div>
      )}

      <div class="wrap post-content">
        <Content />
      </div>
    </article>
  </main>
  <Footer />
</BaseLayout>

<style>
  .post-hero {
    padding: 138px 0 54px;
    background: var(--kuri-ink);
    color: var(--kuri-white);
  }

  .back-link,
  .post-hero span {
    display: inline-block;
    margin: 0 0 16px;
    color: rgb(255 255 255 / 74%);
    font-weight: 900;
    text-decoration: none;
    text-transform: uppercase;
  }

  .back-link {
    margin-right: 18px;
    color: var(--kuri-white);
  }

  .post-hero h1 {
    max-width: 920px;
    margin-bottom: 18px;
    font-size: clamp(2.7rem, 6vw, 5.4rem);
    line-height: 0.96;
  }

  .post-hero p {
    max-width: 760px;
    color: rgb(255 255 255 / 84%);
    font-size: 1.18rem;
  }

  .post-hero time {
    color: rgb(255 255 255 / 70%);
  }

  .post-cover {
    margin-top: 42px;
  }

  .post-cover img {
    width: 100%;
    max-height: 480px;
    border-radius: 8px;
    object-fit: cover;
  }

  .post-content {
    max-width: 840px;
    padding: 54px 0 82px;
  }

  .post-content :global(h2) {
    margin-top: 42px;
    font-size: clamp(1.9rem, 4vw, 3rem);
  }

  .post-content :global(p),
  .post-content :global(li) {
    color: var(--kuri-grey);
    font-size: 1.05rem;
  }

  .post-content :global(a) {
    color: var(--kuri-red);
    font-weight: 800;
  }

  .post-content :global(blockquote) {
    margin: 28px 0;
    padding: 20px 22px;
    border-left: 4px solid var(--kuri-red);
    background: var(--kuri-light);
    color: var(--kuri-ink);
    font-weight: 800;
  }
</style>
